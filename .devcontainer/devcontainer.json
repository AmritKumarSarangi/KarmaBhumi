{
    "name": "KarmaBhumi Exchange",
    "image": "mcr.microsoft.com/devcontainers/universal:2",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },
    "forwardPorts": [3000, 8000, 3001, 8090],
    "portsAttributes": {
        "3000": {
            "label": "Web Dashboard (React)",
            "onAutoForward": "notify"
        },
        "8000": {
            "label": "API Gateway (FastAPI)",
            "onAutoForward": "silent"
        },
        "3001": {
            "label": "Grafana Analytics",
            "onAutoForward": "silent"
        },
        "8090": {
            "label": "Kafka UI",
            "onAutoForward": "silent"
        }
    },
    "postCreateCommand": "docker-compose up -d --build && echo 'Waiting 15 seconds for databases to init...' && sleep 15 && docker exec exchangex-backend python scripts/seed_data.py && echo 'Ready! Open port 3000 in your browser.'"
}
