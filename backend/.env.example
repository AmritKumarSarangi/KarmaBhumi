# .env.example – copy to .env and fill in real values

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=postgresql+asyncpg://exchange:exchange@postgres:5432/exchange

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=exchange-backend-group

# ── Matching Engine gRPC ──────────────────────────────────────────────────────
MATCHING_ENGINE_HOST=matching-engine
MATCHING_ENGINE_PORT=50051

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# IMPORTANT: Generate a proper secret with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Order book Redis TTL ──────────────────────────────────────────────────────
ORDER_BOOK_CACHE_TTL_SECONDS=2
